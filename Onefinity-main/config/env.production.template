# Onefinity CNC Controller - Production Environment Configuration
# Copy this file to /opt/onefinity/config/.env and customize as needed

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV=production
LOG_LEVEL=info

# ============================================================================
# BACKEND SETTINGS
# ============================================================================
PORT=4000

# ============================================================================
# REDIS SETTINGS
# ============================================================================
# For Docker deployment (service name)
REDIS_URL=redis://redis:6379

# For native deployment (localhost)
# REDIS_URL=redis://localhost:6379

# ============================================================================
# FRONTEND SETTINGS
# ============================================================================
# Leave empty for same-origin API calls (recommended for production)
VITE_API_URL=

# For development or custom backend URL
# VITE_API_URL=http://localhost:6070

# ============================================================================
# DOCKER SETTINGS
# ============================================================================
# Dozzle log viewer port
DOZZLE_PORT=6040

# ============================================================================
# DEPLOYMENT MODE
# ============================================================================
# Options: docker, native
DEPLOYMENT_MODE=docker

# ============================================================================
# SECURITY SETTINGS (change in production!)
# ============================================================================
# Default user password (change on first boot!)
DEFAULT_USER_PASSWORD=changeme

# ============================================================================
# NETWORK SETTINGS
# ============================================================================
# Hostname for mDNS
HOSTNAME=onefinity-cnc

# ============================================================================
# KIOSK SETTINGS
# ============================================================================
# URL to load in kiosk mode
KIOSK_URL=http://localhost:6080

# Kiosk mode enabled (true/false)
KIOSK_ENABLED=true

# Hide cursor after inactivity (seconds, 0 to disable)
CURSOR_HIDE_TIMEOUT=5

# ============================================================================
# HARDWARE SETTINGS
# ============================================================================
# Serial port (auto-detected, but can be specified)
# SERIAL_PORT=/dev/ttyUSB0

# Baud rate for GRBL communication
SERIAL_BAUDRATE=115200

# ============================================================================
# SYSTEM OPTIMIZATION
# ============================================================================
# Swap size in MB (set to 0 to disable)
SWAP_SIZE=1024

# GPU memory in MB
GPU_MEM=256

# ============================================================================
# MONITORING
# ============================================================================
# Enable health checks (true/false)
HEALTH_CHECK_ENABLED=true

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=60

# ============================================================================
# BACKUP SETTINGS
# ============================================================================
# Backup directory
BACKUP_DIR=/opt/onefinity/backups

# Keep last N backups
BACKUP_KEEP=5

# ============================================================================
# UPDATE SETTINGS
# ============================================================================
# Auto-update enabled (true/false)
AUTO_UPDATE_ENABLED=false

# Check for updates interval (hours)
UPDATE_CHECK_INTERVAL=24
