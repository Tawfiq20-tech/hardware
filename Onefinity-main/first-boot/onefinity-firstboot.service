[Unit]
Description=Onefinity CNC First Boot Setup Wizard
Documentation=https://github.com/your-repo/onefinity
After=network-online.target
Wants=network-online.target
Before=lightdm.service
ConditionPathExists=!/opt/onefinity/.first-boot-complete

[Service]
Type=oneshot
RemainAfterExit=no
ExecStart=/opt/onefinity/first-boot/onefinity-setup-wizard.sh
StandardOutput=journal+console
StandardError=journal+console
TimeoutSec=0

[Install]
WantedBy=multi-user.target
