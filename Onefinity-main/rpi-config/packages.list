xserver-xorg
xserver-xorg-core
xserver-xorg-input-all
xserver-xorg-video-all
x11-xserver-utils
x11-utils
xinit
xauth

# Display Manager
lightdm
lightdm-gtk-greeter

# Chromium Browser (for kiosk mode)
chromium-browser
chromium-codecs-ffmpeg-extra

# Desktop utilities
unclutter
xdotool
wmctrl
xautomation

# ============================================================================
# TOUCHSCREEN SUPPORT
# ============================================================================
libinput-tools
libinput10
xserver-xorg-input-libinput
xinput
xinput-calibrator
evtest

# ============================================================================
