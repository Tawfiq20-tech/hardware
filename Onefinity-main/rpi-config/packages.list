# Onefinity CNC Controller - Required Debian Packages
# This file lists all packages needed for the Raspberry Pi OS image

# ============================================================================
# SYSTEM CORE
# ============================================================================
apt-transport-https
ca-certificates
gnupg
lsb-release
software-properties-common

# ============================================================================
# DEVELOPMENT TOOLS
# ============================================================================
build-essential
git
cmake
pkg-config
libtool
autoconf
automake

# ============================================================================
# PROGRAMMING LANGUAGES & RUNTIMES
# ============================================================================
# Node.js (for backend)
nodejs
npm

# Python (for utilities and scripts)
python3
python3-pip
python3-dev
python3-setuptools
python3-wheel
python3-venv

# ============================================================================
# WEB SERVERS & REVERSE PROXIES
# ============================================================================
nginx
nginx-common
nginx-core

# ============================================================================
# DATABASES & CACHING
# ============================================================================
redis-server
redis-tools

# ============================================================================
# CONTAINERIZATION
# ============================================================================
docker.io
docker-compose
containerd
runc

# ============================================================================
